# Leave blank for the local in-memory demo.
# Never commit a real CockroachDB URL or runtime token.
VITE_RUNTIME_MODE=demo
# Set only after the read-only Lambda endpoint has been deployed.
# The browser never receives a CockroachDB connection URL.
VITE_RUNTIME_API_URL=

# Used only by the AWS Lambda runtime. The demo deploys this as a NoEcho
# CloudFormation parameter into Lambda's encrypted environment. Do not commit it.
DATABASE_URL=
RUNTIME_WRITE_TOKEN=
ARTIFACT_BUCKET=
